<yoga:View
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yoga="clr-namespace:WorldXaml.UI.Yoga;assembly=WorldXaml.UI.Yoga"
    xmlns:ui="clr-namespace:NFMWorld.UI"
    x:Class="NFMWorld.UI.Hud.LapTimerSplitsView"
    FlexDirection="Column"
    AlignItems="FlexStart"
    JustifyContent="Center"
    Gap="10"
    Padding="10">

    <!-- Lap Display Row -->
    <yoga:Box Name="LapDisplay"
              FlexDirection="Row">

        <ui:TextRun Name="LapIcon"
                      Font="bold 24px Adventure"
                      Color="white"
                      StrokeColor="black"
                      Flex="1"
                      MarginRight="5">
            Lap:
        </ui:TextRun>

        <ui:TextBlock Name="LapText"
                        Font="bold 24px DroidSans"
                        Color="white"
                        StrokeColor="black"
                        Flex="1">
            1/3
        </ui:TextBlock>
    </yoga:Box>

</yoga:View>