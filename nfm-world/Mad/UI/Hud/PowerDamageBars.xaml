<yoga:Box
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yoga="clr-namespace:WorldXaml.UI.Yoga;assembly=WorldXaml.UI.Yoga"
    xmlns:ui="clr-namespace:NFMWorld.UI"
    x:Class="NFMWorld.UI.Hud.PowerDamageBars"
    Top="0"
    Padding="10"
    FlexDirection="Column"
    Gap="10"
    AlignItems="FlexEnd">

    <ui:MeasureBar
        Name="DamageBar"
        FillAmount="0"
        ImageData="{ui:StaticImage data/images/damage.gif}"
        Scale="1.2" />

    <ui:MeasureBar
        Name="PowerBar"
        FillAmount="0.98"
        ImageData="{ui:StaticImage data/images/power.gif}"
        Scale="1.2" />
</yoga:Box>