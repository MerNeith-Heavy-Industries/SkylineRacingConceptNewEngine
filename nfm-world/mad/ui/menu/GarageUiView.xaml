<?xml version="1.0" encoding="utf-8"?>

<View xmlns="clr-namespace:nfm_world.ui.yoga"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:Class="nfm_world.ui.menu.GarageUiView"
      Name="LapTimerSplits"
      FlexDirection="Column"
      AlignItems="FlexStart"
      JustifyContent="FlexStart"
      Gap="10"
      Padding="10"
      Margin="50">

    <Box FlexDirection="Row" Gap="25" MarginBottom="25">
        <GarageDynamicStatBar Name="Bar0" StatName="Top Speed" />
        <GarageDynamicStatBar Name="Bar1" StatName="Acceleration" />
        <GarageDynamicStatBar Name="Bar2" StatName="Handling" />
    </Box>
    <Box FlexDirection="Row" Gap="25" MarginBottom="25">
        <GarageDynamicStatBar Name="Bar3" StatName="Power Save" />
        <GarageDynamicStatBar Name="Bar4" StatName="Strength" />
        <GarageDynamicStatBar Name="Bar5" StatName="Max Health" />
    </Box>
    <Box FlexDirection="Row" Gap="25" MarginBottom="25">
        <GarageDynamicStatBar Name="Bar6" StatName="Stunting" />
        <GarageDynamicStatBar Name="Bar7" StatName="Hypergliding" />
        <GarageDynamicStatBar Name="Bar8" StatName="AB'ing" />
    </Box>
</View>