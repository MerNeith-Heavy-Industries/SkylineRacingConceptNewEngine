<?xml version="1.0" encoding="utf-8"?>

<yoga:Box
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yoga="clr-namespace:NFMWorld.UI.Yoga"
    x:Class="nfm_world.ui.hud.PowerDamageBars"
      Top="0"
      Padding="10"
      FlexDirection="Column"
      Gap="10"
      AlignItems="FlexEnd">

    <yoga:MeasureBar
        Name="DamageBar"
        FillAmount="0"
        ImageData="{yoga:StaticImage data/images/damage.gif}"
        Scale="1.2"
        />

    <yoga:MeasureBar
        Name="PowerBar"
        FillAmount="0.98"
        ImageData="{yoga:StaticImage data/images/power.gif}"
        Scale="1.2"
        />
</yoga:Box>