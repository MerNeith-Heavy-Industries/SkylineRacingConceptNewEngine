<?xml version="1.0" encoding="utf-8"?>

<View xmlns="clr-namespace:nfm_world.ui.yoga"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:Class="nfm_world.ui.hud.LapTimerSplitsView"
      FlexDirection="Column"
      AlignItems="FlexStart"
      JustifyContent="Center"
      Gap="10"
      Padding="10">

    <!-- Lap Display Row -->
    <Box Name="LapDisplay"
         FlexDirection="Row">

        <TextRun Name="LapIcon"
                 Font="bold 24px Adventure"
                 Color="white"
                 StrokeColor="black"
                 Flex="1"
                 MarginRight="5">
            Lap:
        </TextRun>

        <TextBlock Name="LapText"
                   Font="bold 24px DroidSans"
                   Color="white"
                   StrokeColor="black"
                   Flex="1">
            1/3
        </TextBlock>
    </Box>

</View>