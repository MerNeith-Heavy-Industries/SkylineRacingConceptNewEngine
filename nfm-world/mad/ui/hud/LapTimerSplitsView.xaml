<?xml version="1.0" encoding="utf-8"?>

<yoga:View
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:yoga="clr-namespace:NFMWorld.UI.Yoga"
    x:Class="nfm_world.ui.hud.LapTimerSplitsView"
      FlexDirection="Column"
      AlignItems="FlexStart"
      JustifyContent="Center"
      Gap="10"
      Padding="10">

    <!-- Lap Display Row -->
    <yoga:Box Name="LapDisplay"
         FlexDirection="Row">

        <yoga:TextRun Name="LapIcon"
                 Font="bold 24px Adventure"
                 Color="white"
                 StrokeColor="black"
                 Flex="1"
                 MarginRight="5">
            Lap:
        </yoga:TextRun>

        <yoga:TextBlock Name="LapText"
                   Font="bold 24px DroidSans"
                   Color="white"
                   StrokeColor="black"
                   Flex="1">
            1/3
        </yoga:TextBlock>
    </yoga:Box>

</yoga:View>