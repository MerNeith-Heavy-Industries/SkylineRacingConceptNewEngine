<?xml version="1.0" encoding="utf-8"?>

<Node xmlns="clr-namespace:nfm_world.ui.yoga"
      xmlns:elements="clr-namespace:nfm_world.ui.elements"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:Class="nfm_world.ui.hud.LapTimerSplitsView"
      FlexDirection="YGFlexDirectionColumn"
      AlignItems="YGAlignFlexStart"
      JustifyContent="YGJustifyCenter"
      Gap="10"
      Padding="10">

    <!-- Lap Display Row -->
    <Node Name="LapDisplay"
          FlexDirection="YGFlexDirectionRow">

        <elements:TextRun Name="LapIcon"
                          Font="Adventure,1,24"
                          Color="255,255,255,255"
                          StrokeColor="0,0,0,255"
                          Text="Lap: "
                          Flex="1" />

        <elements:TextBlock Name="LapText"
                            Font="DroidSans,1,24"
                            Color="255,255,255,255"
                            StrokeColor="0,0,0,255"
                            Text="1/3"
                            Flex="1" />
    </Node>

</Node>