<?xml version="1.0" encoding="utf-8"?>
<Node xmlns="clr-namespace:nfm_world.ui.yoga"
      xmlns:elements="clr-namespace:nfm_world.ui.elements"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:Class="nfm_world.ui.hud.TTLapTimerSplitsView"
      Name="LapTimerSplits"
      FlexDirection="Column"
      AlignItems="FlexStart"
      JustifyContent="Center"
      Gap="10"
      Padding="10">

    <Node Name="LapDisplay" FlexDirection="Row">
        <elements:TextRun Name="LapIcon"
                         Font="bold 24px Adventure"
                         Color="white"
                         StrokeColor="black"
                         Text="Lap: "
                         Flex="1" />
        <elements:TextRun Name="LapText"
                         StrokeColor="black"
                         Color="white"
                         Font="bold 24px DroidSans"
                         Flex="1" />
    </Node>

    <Node Name="TimeDisplay" FlexDirection="Row">
        <elements:TextRun Name="TimeIcon"
                         Font="bold 24px Adventure"
                         Color="white"
                         StrokeColor="black"
                         Text="Time: "
                         Flex="1" />
        <elements:TextRun Name="TimeText"
                         StrokeColor="black"
                         Color="white"
                         Font="bold 24px DroidSans"
                         Flex="1" />
    </Node>

    <Node>
        <elements:TextRun Name="LapTimeText"
                         StrokeColor="black"
                         Color="white"
                         Font="bold 24px DroidSans"
                         Flex="1" />
    </Node>

    <Node>
        <elements:TextRun Name="CheckpointSplitsText"
                         StrokeColor="black"
                         Color="white"
                         Font="bold 24px DroidSans"
                         Flex="1" />
    </Node>

    <Node>
        <elements:TextRun Name="LapSplitsText"
                         StrokeColor="black"
                         Color="white"
                         Font="bold 24px DroidSans"
                         Flex="1" />
    </Node>
</Node>
