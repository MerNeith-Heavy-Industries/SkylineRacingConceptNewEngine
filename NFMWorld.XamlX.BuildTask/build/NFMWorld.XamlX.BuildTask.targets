<!-- NFMWorld.XamlX.BuildTask MSBuild Targets -->
<!-- This file is imported by projects that want to compile XAML files -->
<Project>

  <PropertyGroup>
    <!-- Try to find the task DLL in the same configuration first, then try Debug -->
    <NFMWorldXamlXTasksDir Condition="'$(NFMWorldXamlXTasksDir)' == '' AND Exists('$(MSBuildThisFileDirectory)..\bin\$(Configuration)\net10.0\NFMWorld.XamlX.BuildTask.dll')">$(MSBuildThisFileDirectory)..\bin\$(Configuration)\net10.0\</NFMWorldXamlXTasksDir>
    <NFMWorldXamlXTasksDir Condition="'$(NFMWorldXamlXTasksDir)' == '' AND Exists('$(MSBuildThisFileDirectory)..\bin\Debug\net10.0\NFMWorld.XamlX.BuildTask.dll')">$(MSBuildThisFileDirectory)..\bin\Debug\net10.0\</NFMWorldXamlXTasksDir>
    <NFMWorldXamlXTasksDir Condition="'$(NFMWorldXamlXTasksDir)' == '' AND Exists('$(MSBuildThisFileDirectory)..\bin\Release\net10.0\NFMWorld.XamlX.BuildTask.dll')">$(MSBuildThisFileDirectory)..\bin\Release\net10.0\</NFMWorldXamlXTasksDir>
  </PropertyGroup>

  <!-- Register our custom item type for XAML files -->
  <ItemGroup>
    <AvailableItemName Include="AvaloniaXaml" />
  </ItemGroup>

  <!-- Import the task assembly -->
  <UsingTask
    TaskName="NFMWorld.XamlX.BuildTask.CompileXamlTask"
    AssemblyFile="$(NFMWorldXamlXTasksDir)NFMWorld.XamlX.BuildTask.dll"
    Condition="Exists('$(NFMWorldXamlXTasksDir)NFMWorld.XamlX.BuildTask.dll')" />

  <!-- Generate refs file for the task -->
  <Target Name="_GenerateXamlRefsFile"
          BeforeTargets="_CompileYogaXamlInternal"
          Condition="'@(AvaloniaXaml)' != '' AND '$(IntermediateOutputPath)' != ''">
    <ItemGroup>
      <_XamlRefAssemblies Include="@(ReferencePath)" />
    </ItemGroup>

    <PropertyGroup>
      <_XamlRefsFile>$(IntermediateOutputPath)xamlrefs.txt</_XamlRefsFile>
    </PropertyGroup>

    <Message Text="Generating XAML refs file: $(_XamlRefsFile)" Importance="Low" />

    <WriteLinesToFile
      File="$(_XamlRefsFile)"
      Lines="@(_XamlRefAssemblies)"
      Overwrite="true"
      Condition="'$(_XamlRefsFile)' != ''" />
  </Target>

  <!-- Hook into the compilation pipeline using TargetsTriggeredByCompilation -->
  <Target Name="_SetupYogaXamlCompilation" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <TargetsTriggeredByCompilation>$(TargetsTriggeredByCompilation);_CompileYogaXamlInternal</TargetsTriggeredByCompilation>
    </PropertyGroup>
  </Target>

  <!-- Internal target that does the actual XAML compilation -->
  <!-- This will be triggered as part of the compilation pipeline -->
  <Target Name="_CompileYogaXamlInternal"
          Outputs="$(IntermediateOutputPath)xaml.compiled.marker">

    <ItemGroup>
      <IntermediateAssembly Update="*"/>
      <_DebugSymbolsIntermediatePath Update="*"/>
      <IntermediateRefAssembly Update="*"/>
    </ItemGroup>

    <PropertyGroup>
      <!-- Use the intermediate assembly which is available after CoreCompile -->
      <_XamlAssemblyPath>@(IntermediateAssembly)</_XamlAssemblyPath>
    </PropertyGroup>

    <Message Text="Compiling Yoga XAML files (triggered by compilation)..." Importance="High" />
    <Message Text="  Assembly: $(_XamlAssemblyPath)" Importance="Normal" />
    <Message Text="  Task DLL: $(NFMWorldXamlXTasksDir)NFMWorld.XamlX.BuildTask.dll" Importance="Normal" />

    <CompileXamlTask
      AssemblyPath="$(_XamlAssemblyPath)"
      ReferencesFile="$(IntermediateOutputPath)xamlrefs.txt"
      XamlFiles="@(AvaloniaXaml)"
      OutputPath="$(_XamlAssemblyPath)" />

    <!-- Create a marker file to indicate compilation happened -->
    <Touch Files="$(IntermediateOutputPath)xaml.compiled.marker" AlwaysCreate="true" />
  </Target>

  <!-- Public target for manual invocation -->
  <Target Name="CompileYogaXaml" DependsOnTargets="_CompileYogaXamlInternal" />

  <!-- Clean up XAML compilation artifacts -->
  <Target Name="CleanYogaXamlArtifacts" AfterTargets="Clean">
    <Delete Files="$(IntermediateOutputPath)xamlrefs.txt" Condition="Exists('$(IntermediateOutputPath)xamlrefs.txt')" />
    <Delete Files="$(IntermediateOutputPath)xaml.compiled.marker" Condition="Exists('$(IntermediateOutputPath)xaml.compiled.marker')" />
  </Target>

</Project>
